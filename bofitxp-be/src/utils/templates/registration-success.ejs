<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BoFitXp - Activation User</title>
    <style>
      body {
        font-family: Arial, Helvetica, sans-serif;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        background-color: #f4f4f4;
      }

      .container {
        max-width: 600px;
        margin: 2px auto;
        background-color: #ffffff;
        border: 1px solid #dddd;
        border-radius: 5px;

        overflow: hidden;
      }

      .activation-code {
        padding: 1rem;
        border-radius: 12px;
        margin-inline: auto;
        margin-block: -4px;
        width: fit-content;
        font-weight: 700;
        color: white;
        letter-spacing: 10px;
        font-size: 40px;
        background-color: #6c3fff;
      }

      .container-code {
        width: 100%;
      }

      .header {
        background-color: #6c3fff;
        padding: 5px;
        color: white;
        text-align: center;
      }
      .content {
        padding: 20px;
      }
      .footer {
        background-color: #f1f1f1;
        padding: 10px;
        text-align: center;
        font-size: 12px;
        color: #555555;
      }
      .button {
        display: inline-block;
        padding: 10px 20px;
        margin: 20px 0;
        background-color: rgb(112, 112, 236);
        color: white;
        font-weight: 600;
        text-decoration: none;
        border-radius: 5px;
      }

      @media (max-width: 600px) {
        .container {
          width: 100%;
          margin: 0;
          border-radius: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Welcome!</h1>
      </div>
      <div class="content">
        <p>Halo <%=username%>,</p>
        <p>
          Thank you for registering for our service. Here is your account
          information. :
        </p>
        <ul>
          <li><strong>Name: </strong> <%=fullName %></li>
          <li><strong>Email: </strong> <%=email %></li>
          <li><strong>Registration Date: </strong> <%=createdAt%></li>
        </ul>
        <p>This is your Activation Code:</p>
        <div class="container-code">
          <p class="activation-code"><%=activationCode%></p>
        </div>
        <p>If you have any questions please feel free to contact us .</p>
        <p>Best Regards, BoFitXp Team</p>
      </div>
      <div class="footer">
        <p>Copy; 2026 BoFitXp. All Rights Reserved</p>
      </div>
    </div>
  </body>
</html>
